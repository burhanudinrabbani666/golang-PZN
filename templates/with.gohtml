<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
</head>
<body>
  <h1>{{.Name}}</h1>

  {{with .Address}}
  <p>Address street: {{.Street}}</p>
  <p>Address City: {{.City}}</p>
  {{else}}
  <p>Dont have any address</p>
  {{end}}

</body>
</html>