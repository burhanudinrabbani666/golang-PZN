<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
</head>
<body>

  <h1>My Hobbies:</h1>

  <ul>
    {{range $index, $element := .Hobbies}}
    <li>{{$element}}</li>
    {{else}}
    <li>You dont have any hobbies</li>
    {{end}}
  </ul>

</body>
</html>